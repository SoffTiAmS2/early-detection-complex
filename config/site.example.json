{
  "version": 1,
  "site": {
    "name": "early-detection-complex",
    "central_url": "http://192.168.0.196:8080",
    "management_network": "192.168.0.0/24"
  },
  "sensors": [
    {
      "id": "banana-pi-pro-1",
      "host": "192.168.0.239",
      "architecture": "armv7l",
      "enrollment": {
        "method": "ansible",
        "ssh_user": "banana",
        "ssh_port": 22
      },
      "desired_state": {
        "runtime_mode": "docker",
        "profile": "full_stack",
        "persona": {
          "hostname": "edge-gateway-01",
          "department": "Infrastructure",
          "os": "Debian GNU/Linux",
          "asset_tag": "EDGE-GW-01"
        },
        "modules": [
          {
            "id": "cowrie",
            "enabled": true,
            "services": [
              { "id": "ssh", "enabled": true, "host_port": 2222 },
              { "id": "telnet", "enabled": true, "host_port": 2223 }
            ],
            "settings": {
              "hostname": "edge-gateway-01",
              "ssh_version": "SSH-2.0-OpenSSH_8.4",
              "userdb_entries": "root:x:!root\nadmin:x:admin",
              "raw_cowrie_cfg": "",
              "image_mode": "local",
              "base_image": "arm32v7/debian:bookworm-slim",
              "cowrie_ref": "v2.6.1"
            }
          },
          {
            "id": "conpot",
            "enabled": true,
            "services": [
              { "id": "modbus", "enabled": true, "host_port": 15020 },
              { "id": "s7comm", "enabled": true, "host_port": 10102 },
              { "id": "bacnet", "enabled": true, "host_port": 47808 },
              { "id": "http", "enabled": true, "host_port": 8800 }
            ],
            "settings": {
              "template": "default",
              "raw_conpot_cfg": "",
              "hpfriends.enabled": false,
              "hpfriends.host": "hpfriends.honeycloud.net",
              "hpfriends.port": 20000,
              "hpfriends.channels": "conpot.events"
            }
          },
          {
            "id": "mailoney",
            "enabled": true,
            "services": [
              { "id": "smtp", "enabled": true, "host_port": 2525 }
            ],
            "settings": {
              "hostname": "mail-gw-01",
              "smtp_banner": "220 mail.example.local ESMTP",
              "log_path": "/logs/mailoney.log",
              "raw_mailoney_cfg": "",
              "image_mode": "local",
              "base_image": "python:3.11-slim"
            }
          },
          {
            "id": "honeypy",
            "enabled": true,
            "services": [
              { "id": "http", "enabled": true, "host_port": 8082 },
              { "id": "mysql", "enabled": true, "host_port": 3307 },
              { "id": "redis", "enabled": true, "host_port": 6380 },
              { "id": "ftp", "enabled": true, "host_port": 2124 },
              { "id": "telnet", "enabled": true, "host_port": 2324 }
            ],
            "settings": {
              "sensor_name": "web-stack-01",
              "log_path": "/logs/honeypy.log",
              "raw_honeypy_yml": "",
              "image_mode": "local",
              "base_image": "python:3.11-slim"
            }
          },
          {
            "id": "glutton",
            "enabled": true,
            "services": [
              { "id": "docker_api", "enabled": true, "host_port": 2375 },
              { "id": "mqtt", "enabled": true, "host_port": 1883 },
              { "id": "k8s_api", "enabled": true, "host_port": 6443 },
              { "id": "rdp", "enabled": true, "host_port": 3389 },
              { "id": "vnc", "enabled": true, "host_port": 5900 },
              { "id": "sip", "enabled": true, "host_port": 5060 }
            ],
            "settings": {
              "log_path": "/logs/glutton.json",
              "raw_glutton_yml": "",
              "image_mode": "local",
              "base_image": "golang:1.22-bookworm"
            }
          }
        ]
      }
    }
  ]
}
