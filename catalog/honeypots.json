{
  "version": 2,
  "modules": [
    {
      "id": "cowrie",
      "title": "Cowrie",
      "source": "https://github.com/cowrie/cowrie",
      "documentation": "https://docs.cowrie.org/en/stable/",
      "purpose": "SSH/Telnet high-interaction deception with fake filesystem, shell, downloads and session logging",
      "priority": 1,
      "status": "prototype-v0-tested",
      "runtime": "container-module",
      "resource_class": "light",
      "services": [
        {
          "id": "ssh",
          "protocol": "tcp",
          "container_port": 2222,
          "default_host_port": 2222,
          "events": ["connect", "login", "command", "download", "session"]
        },
        {
          "id": "telnet",
          "protocol": "tcp",
          "container_port": 2223,
          "default_host_port": 2223,
          "events": ["connect", "login", "command", "session"]
        }
      ],
      "config_contract": [
        "sensor_name",
        "hostname",
        "backend",
        "auth_class",
        "auth_class_parameters",
        "userdb_entries",
        "filesystem",
        "contents_path",
        "txtcmds_path",
        "download_limit_size",
        "ttylog",
        "idle_timeout",
        "authentication_timeout",
        "logtype",
        "timezone",
        "prompt",
        "fake_addr",
        "internet_facing_ip",
        "kernel_version",
        "hardware_platform",
        "operating_system",
        "ssh_version",
        "shell_arch",
        "proxy_backend",
        "raw_cowrie_cfg"
      ],
      "config_schema": [
        {"key": "sensor_name", "label": "Sensor name", "type": "string", "group": "General", "default": "office-filesrv-01", "help": "Cowrie sensor name used in logs and output integrations."},
        {"key": "hostname", "label": "Shell hostname", "type": "string", "group": "General", "default": "office-filesrv-01", "help": "Hostname shown in the emulated shell prompt."},
        {"key": "backend", "label": "Backend", "type": "select", "group": "General", "default": "shell", "options": ["shell", "proxy", "llm"], "help": "Cowrie backend: emulated shell, SSH/Telnet proxy or LLM backend."},
        {"key": "logtype", "label": "Log type", "type": "select", "group": "General", "default": "rotating", "options": ["rotating", "plain"]},
        {"key": "timezone", "label": "Timezone", "type": "string", "group": "General", "default": "UTC"},
        {"key": "prompt", "label": "Custom shell prompt", "type": "string", "group": "General", "default": "", "help": "Optional prompt override; empty keeps Cowrie default path-aware prompt."},
        {"key": "auth_class", "label": "Auth class", "type": "select", "group": "Authentication", "default": "UserDB", "options": ["UserDB", "AuthRandom"], "help": "UserDB uses configured credentials; AuthRandom allows login after a random attempt window."},
        {"key": "auth_class_parameters", "label": "AuthRandom parameters", "type": "string", "group": "Authentication", "default": "2, 5, 10", "help": "min attempts, max attempts, credential cache size."},
        {"key": "userdb_entries", "label": "userdb.txt entries", "type": "textarea", "group": "Authentication", "default": "root:x:!root\nbackup:x:backup123\nadmin:x:admin", "help": "One Cowrie userdb entry per line."},
        {"key": "filesystem", "label": "Fake filesystem metadata", "type": "string", "group": "Fake Filesystem", "default": "${honeypot:data_path}/fs.pickle", "help": "Cowrie fs.pickle metadata path. This is the fakefs control point."},
        {"key": "contents_path", "label": "honeyfs contents path", "type": "string", "group": "Fake Filesystem", "default": "honeyfs", "help": "Directory with file contents shown by commands like cat."},
        {"key": "txtcmds_path", "label": "txtcmds path", "type": "string", "group": "Fake Filesystem", "default": "txtcmds", "help": "Directory with simple command output files."},
        {"key": "processes", "label": "ps command output", "type": "string", "group": "Fake Filesystem", "default": "${honeypot:data_path}/cmdoutput.json"},
        {"key": "download_limit_size", "label": "Download limit bytes", "type": "integer", "group": "Downloads and Sessions", "default": 10485760, "min": 0, "help": "0 means unlimited. Cowrie stores attacker uploads/downloads under download_path."},
        {"key": "download_path", "label": "Download artifact path", "type": "string", "group": "Downloads and Sessions", "default": "${honeypot:state_path}/downloads"},
        {"key": "ttylog", "label": "Enable TTY logs", "type": "boolean", "group": "Downloads and Sessions", "default": true},
        {"key": "ttylog_path", "label": "TTY log path", "type": "string", "group": "Downloads and Sessions", "default": "${honeypot:state_path}/tty"},
        {"key": "idle_timeout", "label": "Idle timeout seconds", "type": "integer", "group": "Timeouts", "default": 180, "min": 1},
        {"key": "authentication_timeout", "label": "Authentication timeout seconds", "type": "integer", "group": "Timeouts", "default": 120, "min": 1},
        {"key": "out_addr", "label": "Outgoing bind address", "type": "string", "group": "Network Persona", "default": ""},
        {"key": "fake_addr", "label": "Fake client-visible address", "type": "string", "group": "Network Persona", "default": "192.168.66.254"},
        {"key": "internet_facing_ip", "label": "Internet-facing IPv4", "type": "string", "group": "Network Persona", "default": ""},
        {"key": "internet_facing_ipv6", "label": "Internet-facing IPv6", "type": "string", "group": "Network Persona", "default": ""},
        {"key": "shell_arch", "label": "Shell architecture", "type": "string", "group": "Shell Persona", "default": "linux-x64-lsb"},
        {"key": "kernel_version", "label": "uname kernel version", "type": "string", "group": "Shell Persona", "default": "3.2.0-4-amd64"},
        {"key": "kernel_build_string", "label": "uname kernel build", "type": "string", "group": "Shell Persona", "default": "#1 SMP Debian 3.2.68-1+deb7u1"},
        {"key": "hardware_platform", "label": "uname hardware platform", "type": "string", "group": "Shell Persona", "default": "x86_64"},
        {"key": "operating_system", "label": "uname operating system", "type": "string", "group": "Shell Persona", "default": "GNU/Linux"},
        {"key": "ssh_version", "label": "SSH banner", "type": "string", "group": "SSH/Telnet", "default": "SSH-2.0-OpenSSH_8.4"},
        {"key": "shell_ssh_version", "label": "ssh -V shell output", "type": "string", "group": "SSH/Telnet", "default": "OpenSSH_7.9p1, OpenSSL 1.1.1a 20 Nov 2018"},
        {"key": "proxy_backend", "label": "Proxy backend", "type": "select", "group": "Proxy Backend", "default": "pool", "options": ["simple", "pool"]},
        {"key": "backend_ssh_host", "label": "Backend SSH host", "type": "string", "group": "Proxy Backend", "default": "localhost"},
        {"key": "backend_ssh_port", "label": "Backend SSH port", "type": "integer", "group": "Proxy Backend", "default": 2022, "min": 1, "max": 65535},
        {"key": "backend_telnet_host", "label": "Backend Telnet host", "type": "string", "group": "Proxy Backend", "default": "localhost"},
        {"key": "backend_telnet_port", "label": "Backend Telnet port", "type": "integer", "group": "Proxy Backend", "default": 2023, "min": 1, "max": 65535},
        {"key": "backend_user", "label": "Backend user", "type": "string", "group": "Proxy Backend", "default": "root"},
        {"key": "backend_pass_env", "label": "Backend password env var", "type": "string", "group": "Proxy Backend", "default": "COWRIE_BACKEND_PASS"},
        {"key": "raw_cowrie_cfg", "label": "Advanced cowrie.cfg override", "type": "textarea", "group": "Advanced", "default": "", "help": "Optional raw INI fragment appended by the future real Cowrie runner."}
      ]
    },
    {
      "id": "opencanary",
      "title": "OpenCanary",
      "source": "https://github.com/thinkst/opencanary",
      "documentation": "https://www.opencanary.org/en/latest/starting/configuration.html",
      "purpose": "Lightweight multi-protocol early warning honeypot",
      "priority": 2,
      "status": "planned-first-class",
      "runtime": "container-module",
      "resource_class": "light",
      "services": [
        {"id": "http", "protocol": "tcp", "default_host_port": 8081},
        {"id": "ftp", "protocol": "tcp", "default_host_port": 2121},
        {"id": "smb", "protocol": "tcp", "default_host_port": 445},
        {"id": "redis", "protocol": "tcp", "default_host_port": 6379},
        {"id": "mysql", "protocol": "tcp", "default_host_port": 3306},
        {"id": "mssql", "protocol": "tcp", "default_host_port": 1433}
      ],
      "config_contract": [
        "device.node_id",
        "ip.ignorelist",
        "ftp.banner",
        "http.banner",
        "http.skin",
        "ssh.version",
        "telnet.banner",
        "mysql.banner",
        "smb.auditfile",
        "portscan.enabled",
        "logger",
        "raw_opencanary_conf"
      ],
      "config_schema": [
        {"key": "device.node_id", "label": "Device node id", "type": "string", "group": "Device", "default": "opencanary-sensor1"},
        {"key": "device.listen_addr", "label": "Listen address", "type": "string", "group": "Device", "default": "", "help": "OpenCanary bind address for selected native modules; empty means default."},
        {"key": "ip.ignorelist", "label": "Ignore IPs/CIDRs", "type": "list", "group": "Device", "default": "192.168.0.196", "help": "Comma or newline separated ignore list."},
        {"key": "ftp.banner", "label": "FTP banner", "type": "string", "group": "Service Banners", "default": "FTP server ready"},
        {"key": "http.banner", "label": "HTTP server banner", "type": "string", "group": "Service Banners", "default": "nginx/1.18.0"},
        {"key": "http.skin", "label": "HTTP skin", "type": "select", "group": "Service Banners", "default": "nasLogin", "options": ["basicLogin", "nasLogin"]},
        {"key": "https.skin", "label": "HTTPS skin", "type": "select", "group": "Service Banners", "default": "nasLogin", "options": ["basicLogin", "nasLogin"]},
        {"key": "https.certificate", "label": "HTTPS certificate path", "type": "string", "group": "TLS", "default": "/etc/ssl/opencanary/opencanary.pem"},
        {"key": "https.key", "label": "HTTPS key path", "type": "string", "group": "TLS", "default": "/etc/ssl/opencanary/opencanary.key"},
        {"key": "httpproxy.skin", "label": "HTTP proxy skin", "type": "select", "group": "Service Banners", "default": "squid", "options": ["squid", "ms-isa"]},
        {"key": "mysql.banner", "label": "MySQL banner", "type": "string", "group": "Service Banners", "default": "5.5.43-0ubuntu0.14.04.1"},
        {"key": "ssh.version", "label": "SSH version", "type": "string", "group": "Service Banners", "default": "SSH-2.0-OpenSSH_5.1p1 Debian-4"},
        {"key": "telnet.banner", "label": "Telnet banner", "type": "string", "group": "Service Banners", "default": ""},
        {"key": "telnet.honeycreds", "label": "Telnet honey credentials", "type": "textarea", "group": "Credentials", "default": "admin:TopsyKretts", "help": "One username:password per line; future runner maps to telnet.honeycreds."},
        {"key": "smb.auditfile", "label": "Samba audit log path", "type": "string", "group": "SMB", "default": "/var/log/samba-audit.log"},
        {"key": "portscan.enabled", "label": "Enable portscan watcher", "type": "boolean", "group": "Portscan", "default": false},
        {"key": "portscan.logfile", "label": "Portscan logfile", "type": "string", "group": "Portscan", "default": "/var/log/kern.log"},
        {"key": "portscan.synrate", "label": "Portscan SYN rate", "type": "integer", "group": "Portscan", "default": 5, "min": 1},
        {"key": "portscan.nmaposrate", "label": "Nmap OS rate", "type": "integer", "group": "Portscan", "default": 5, "min": 1},
        {"key": "portscan.lorate", "label": "Low scan rate", "type": "integer", "group": "Portscan", "default": 3, "min": 1},
        {"key": "logger.mode", "label": "Logger mode", "type": "select", "group": "Logging", "default": "file", "options": ["console", "file", "syslog-unix", "json-tcp", "webhook"]},
        {"key": "logger.file", "label": "Logger file", "type": "string", "group": "Logging", "default": "/var/tmp/opencanary.log"},
        {"key": "logger.json_tcp_host", "label": "JSON TCP host", "type": "string", "group": "Logging", "default": "127.0.0.1"},
        {"key": "logger.json_tcp_port", "label": "JSON TCP port", "type": "integer", "group": "Logging", "default": 1514, "min": 1, "max": 65535},
        {"key": "logger.webhook_url", "label": "Webhook URL", "type": "string", "group": "Logging", "default": ""},
        {"key": "raw_opencanary_conf", "label": "Advanced opencanary.conf JSON", "type": "textarea", "group": "Advanced", "default": "", "help": "Optional raw JSON overlay for keys not exposed above."}
      ]
    },
    {
      "id": "heralding",
      "title": "Heralding",
      "source": "https://github.com/johnnykv/heralding",
      "documentation": "https://github.com/johnnykv/heralding",
      "purpose": "Credential-catching low-interaction services",
      "priority": 3,
      "status": "planned",
      "runtime": "container-module",
      "resource_class": "light",
      "services": [
        {"id": "ftp", "protocol": "tcp", "default_host_port": 2122},
        {"id": "http", "protocol": "tcp", "default_host_port": 8082},
        {"id": "pop3", "protocol": "tcp", "default_host_port": 110},
        {"id": "smtp", "protocol": "tcp", "default_host_port": 25}
      ],
      "config_contract": [
        "enabled_protocols",
        "listen_addr",
        "auth_logfile",
        "session_csv_logfile",
        "session_json_logfile",
        "banner_profile",
        "raw_heralding_yml"
      ],
      "config_schema": [
        {"key": "enabled_protocols", "label": "Enabled protocols", "type": "list", "group": "Protocols", "default": "ftp,http,pop3,smtp"},
        {"key": "listen_addr", "label": "Listen address", "type": "string", "group": "Protocols", "default": "0.0.0.0"},
        {"key": "banner_profile", "label": "Banner profile", "type": "string", "group": "Persona", "default": "enterprise-mail-and-ftp"},
        {"key": "credential_policy", "label": "Credential policy", "type": "select", "group": "Persona", "default": "capture-all", "options": ["capture-all", "always-fail", "first-step-only"]},
        {"key": "auth_logfile", "label": "Auth CSV logfile", "type": "string", "group": "Logging", "default": "log_auth.csv"},
        {"key": "session_csv_logfile", "label": "Session CSV logfile", "type": "string", "group": "Logging", "default": "log_session.csv"},
        {"key": "session_json_logfile", "label": "Session JSON logfile", "type": "string", "group": "Logging", "default": "log_session.json"},
        {"key": "raw_heralding_yml", "label": "Advanced heralding.yml", "type": "textarea", "group": "Advanced", "default": ""}
      ]
    },
    {
      "id": "conpot",
      "title": "Conpot",
      "source": "https://github.com/mushorg/conpot",
      "documentation": "https://conpot.readthedocs.io/en/latest/",
      "purpose": "ICS/SCADA deception",
      "priority": 4,
      "status": "planned-after-arm-check",
      "runtime": "container-module",
      "resource_class": "medium",
      "services": [
        {"id": "modbus", "protocol": "tcp", "default_host_port": 502},
        {"id": "http", "protocol": "tcp", "default_host_port": 8800}
      ],
      "config_contract": [
        "template",
        "modbus.host",
        "modbus.port",
        "http.host",
        "http.port",
        "snmp.host",
        "snmp.port",
        "sqlite.enabled",
        "hpfriends.enabled",
        "fetch_public_ip.enabled",
        "raw_conpot_cfg"
      ],
      "config_schema": [
        {"key": "template", "label": "Template", "type": "select", "group": "Template", "default": "default", "options": ["default", "ipmi", "kamstrup_382", "guardian_ast"]},
        {"key": "industrial_persona", "label": "Industrial persona", "type": "string", "group": "Template", "default": "building automation controller"},
        {"key": "protocol_profile", "label": "Protocol profile", "type": "string", "group": "Template", "default": "modbus-http"},
        {"key": "modbus.host", "label": "Modbus host", "type": "string", "group": "Protocols", "default": "0.0.0.0"},
        {"key": "modbus.port", "label": "Modbus container port", "type": "integer", "group": "Protocols", "default": 502, "min": 1, "max": 65535},
        {"key": "http.host", "label": "HTTP host", "type": "string", "group": "Protocols", "default": "0.0.0.0"},
        {"key": "http.port", "label": "HTTP container port", "type": "integer", "group": "Protocols", "default": 80, "min": 1, "max": 65535},
        {"key": "snmp.host", "label": "SNMP host", "type": "string", "group": "Protocols", "default": "0.0.0.0"},
        {"key": "snmp.port", "label": "SNMP port", "type": "integer", "group": "Protocols", "default": 161, "min": 1, "max": 65535},
        {"key": "sqlite.enabled", "label": "Enable sqlite", "type": "boolean", "group": "Storage", "default": false},
        {"key": "hpfriends.enabled", "label": "Enable HPFriends", "type": "boolean", "group": "HPFriends", "default": false, "help": "Can transmit attack data to The Honeynet Project; keep off unless explicitly intended."},
        {"key": "hpfriends.host", "label": "HPFriends host", "type": "string", "group": "HPFriends", "default": "hpfriends.honeycloud.net"},
        {"key": "hpfriends.port", "label": "HPFriends port", "type": "integer", "group": "HPFriends", "default": 20000, "min": 1, "max": 65535},
        {"key": "hpfriends.ident_env", "label": "HPFriends ident env var", "type": "string", "group": "HPFriends", "default": "CONPOT_HPFRIENDS_IDENT"},
        {"key": "hpfriends.secret_env", "label": "HPFriends secret env var", "type": "string", "group": "HPFriends", "default": "CONPOT_HPFRIENDS_SECRET"},
        {"key": "hpfriends.channels", "label": "HPFriends channels", "type": "list", "group": "HPFriends", "default": "conpot.events"},
        {"key": "fetch_public_ip.enabled", "label": "Fetch public IP", "type": "boolean", "group": "Network", "default": true},
        {"key": "fetch_public_ip.url", "label": "Public IP API URL", "type": "string", "group": "Network", "default": "http://api-sth01.exip.org/?call=ip"},
        {"key": "raw_conpot_cfg", "label": "Advanced conpot.cfg", "type": "textarea", "group": "Advanced", "default": ""}
      ]
    },
    {
      "id": "dionaea",
      "title": "Dionaea",
      "source": "https://github.com/DinoTools/dionaea",
      "documentation": "https://dionaea.readthedocs.io/en/latest/",
      "purpose": "Malware/service honeypot",
      "priority": 5,
      "status": "planned-heavy",
      "runtime": "container-module",
      "resource_class": "heavy",
      "services": [
        {"id": "smb", "protocol": "tcp", "default_host_port": 445},
        {"id": "http", "protocol": "tcp", "default_host_port": 8083},
        {"id": "ftp", "protocol": "tcp", "default_host_port": 2123}
      ],
      "config_contract": [
        "services_enabled",
        "downloads_dir",
        "log_json.enabled",
        "submit_http.enabled",
        "hpfeeds.enabled",
        "sqlite.enabled",
        "p0f.enabled",
        "raw_dionaea_conf"
      ],
      "config_schema": [
        {"key": "services_enabled", "label": "Services enabled", "type": "list", "group": "Services", "default": "smb,http,ftp"},
        {"key": "service_config_dir", "label": "Service config dir", "type": "string", "group": "Services", "default": "/etc/dionaea/services-enabled"},
        {"key": "listen.mode", "label": "Listen mode", "type": "select", "group": "Services", "default": "getifaddrs", "options": ["getifaddrs", "manual"]},
        {"key": "downloads_dir", "label": "Malware downloads dir", "type": "string", "group": "Artifacts", "default": "/var/lib/dionaea/binaries"},
        {"key": "artifact_storage", "label": "Artifact storage", "type": "select", "group": "Artifacts", "default": "center", "options": ["local", "center", "s3", "disabled"]},
        {"key": "log_json.enabled", "label": "Enable JSON log", "type": "boolean", "group": "Logging", "default": true},
        {"key": "log_json.path", "label": "JSON log path", "type": "string", "group": "Logging", "default": "/var/log/dionaea/dionaea.json"},
        {"key": "sqlite.enabled", "label": "Enable sqlite", "type": "boolean", "group": "Logging", "default": true},
        {"key": "sqlite.path", "label": "Sqlite DB path", "type": "string", "group": "Logging", "default": "/var/lib/dionaea/dionaea.sqlite"},
        {"key": "submit_http.enabled", "label": "Enable submit_http", "type": "boolean", "group": "Submit", "default": false},
        {"key": "submit_http.url", "label": "submit_http URL", "type": "string", "group": "Submit", "default": ""},
        {"key": "hpfeeds.enabled", "label": "Enable hpfeeds", "type": "boolean", "group": "Submit", "default": false},
        {"key": "hpfeeds.host", "label": "hpfeeds host", "type": "string", "group": "Submit", "default": ""},
        {"key": "hpfeeds.port", "label": "hpfeeds port", "type": "integer", "group": "Submit", "default": 10000, "min": 1, "max": 65535},
        {"key": "p0f.enabled", "label": "Enable p0f processor", "type": "boolean", "group": "Processors", "default": false},
        {"key": "emu.enabled", "label": "Enable emu processor", "type": "boolean", "group": "Processors", "default": true},
        {"key": "raw_dionaea_conf", "label": "Advanced dionaea config overlay", "type": "textarea", "group": "Advanced", "default": ""}
      ]
    }
  ]
}
