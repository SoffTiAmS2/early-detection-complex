{
  "version": 2,
  "modules": [
    {
      "id": "cowrie",
      "title": "Cowrie",
      "source": "https://github.com/cowrie/cowrie",
      "documentation": "https://docs.cowrie.org/en/stable/",
      "purpose": "SSH/Telnet honeypot с высокой интерактивностью: fake filesystem, shell, загрузки и журналирование сессий",
      "priority": 1,
      "status": "prototype-v0-tested",
      "runtime": "container-module",
      "resource_class": "light",
      "services": [
        {
          "id": "ssh",
          "protocol": "tcp",
          "container_port": 2222,
          "default_host_port": 2222,
          "events": [
            "connect",
            "login",
            "command",
            "download",
            "session"
          ]
        },
        {
          "id": "telnet",
          "protocol": "tcp",
          "container_port": 2223,
          "default_host_port": 2223,
          "events": [
            "connect",
            "login",
            "command",
            "session"
          ]
        },
        {
          "id": "metrics",
          "protocol": "tcp",
          "container_port": 9000,
          "default_host_port": 9000,
          "events": [
            "prometheus"
          ]
        }
      ],
      "config_contract": [
        "sensor_name",
        "hostname",
        "backend",
        "auth_class",
        "auth_class_parameters",
        "userdb_entries",
        "filesystem",
        "contents_path",
        "txtcmds_path",
        "download_limit_size",
        "ttylog",
        "idle_timeout",
        "authentication_timeout",
        "logtype",
        "timezone",
        "prompt",
        "fake_addr",
        "internet_facing_ip",
        "kernel_version",
        "hardware_platform",
        "operating_system",
        "ssh_version",
        "shell_arch",
        "proxy_backend",
        "raw_cowrie_cfg"
      ],
      "config_schema": [
        {
          "key": "sensor_name",
          "label": "Имя сенсора",
          "type": "string",
          "group": "Общее",
          "default": "office-filesrv-01",
          "help": "Имя сенсора Cowrie в логах и интеграциях."
        },
        {
          "key": "hostname",
          "label": "Hostname shell",
          "type": "string",
          "group": "Общее",
          "default": "office-filesrv-01",
          "help": "Hostname, который видит атакующий в эмулированном shell."
        },
        {
          "key": "backend",
          "label": "Backend",
          "type": "select",
          "group": "Общее",
          "default": "shell",
          "options": [
            "shell",
            "proxy",
            "llm"
          ],
          "help": "Backend Cowrie: эмулированный shell, SSH/Telnet proxy или LLM backend."
        },
        {
          "key": "logtype",
          "label": "Тип логов",
          "type": "select",
          "group": "Общее",
          "default": "rotating",
          "options": [
            "rotating",
            "plain"
          ]
        },
        {
          "key": "timezone",
          "label": "Часовой пояс",
          "type": "string",
          "group": "Общее",
          "default": "UTC"
        },
        {
          "key": "prompt",
          "label": "Пользовательский shell prompt",
          "type": "string",
          "group": "Общее",
          "default": "",
          "help": "Необязательная замена prompt; пустое значение оставляет стандартный prompt Cowrie."
        },
        {
          "key": "auth_class",
          "label": "Класс аутентификации",
          "type": "select",
          "group": "Аутентификация",
          "default": "UserDB",
          "options": [
            "UserDB",
            "AuthRandom"
          ],
          "help": "UserDB использует заданные учётные данные; AuthRandom разрешает вход после случайного числа попыток."
        },
        {
          "key": "auth_class_parameters",
          "label": "Параметры AuthRandom",
          "type": "string",
          "group": "Аутентификация",
          "default": "2, 5, 10",
          "help": "Минимум попыток, максимум попыток, размер кэша учётных данных."
        },
        {
          "key": "userdb_entries",
          "label": "Записи userdb.txt",
          "type": "textarea",
          "group": "Аутентификация",
          "default": "root:x:!root\nbackup:x:backup123\nadmin:x:admin",
          "help": "Одна запись Cowrie userdb на строку."
        },
        {
          "key": "filesystem",
          "label": "Метаданные fake filesystem",
          "type": "string",
          "group": "Fake Filesystem",
          "default": "${honeypot:data_path}/fs.pickle",
          "help": "Путь к метаданным fs.pickle. Это контрольная точка fakefs."
        },
        {
          "key": "contents_path",
          "label": "Путь honeyfs contents",
          "type": "string",
          "group": "Fake Filesystem",
          "default": "honeyfs",
          "help": "Каталог с содержимым файлов, которое показывают команды вроде cat."
        },
        {
          "key": "txtcmds_path",
          "label": "Путь txtcmds",
          "type": "string",
          "group": "Fake Filesystem",
          "default": "txtcmds",
          "help": "Каталог с простыми файлами вывода команд."
        },
        {
          "key": "processes",
          "label": "Вывод команды ps",
          "type": "string",
          "group": "Fake Filesystem",
          "default": "${honeypot:data_path}/cmdoutput.json"
        },
        {
          "key": "download_limit_size",
          "label": "Лимит загрузки, байт",
          "type": "integer",
          "group": "Загрузки и сессии",
          "default": 10485760,
          "min": 0,
          "help": "0 означает без лимита. Cowrie хранит загрузки атакующего в download_path."
        },
        {
          "key": "download_path",
          "label": "Путь артефактов загрузки",
          "type": "string",
          "group": "Загрузки и сессии",
          "default": "${honeypot:state_path}/downloads"
        },
        {
          "key": "ttylog",
          "label": "Включить TTY-логи",
          "type": "boolean",
          "group": "Загрузки и сессии",
          "default": true
        },
        {
          "key": "ttylog_path",
          "label": "Путь TTY-логов",
          "type": "string",
          "group": "Загрузки и сессии",
          "default": "${honeypot:state_path}/tty"
        },
        {
          "key": "idle_timeout",
          "label": "Idle timeout, секунд",
          "type": "integer",
          "group": "Таймауты",
          "default": 180,
          "min": 1
        },
        {
          "key": "authentication_timeout",
          "label": "Таймаут аутентификации, секунд",
          "type": "integer",
          "group": "Таймауты",
          "default": 120,
          "min": 1
        },
        {
          "key": "out_addr",
          "label": "Исходящий bind-адрес",
          "type": "string",
          "group": "Сетевая легенда",
          "default": ""
        },
        {
          "key": "fake_addr",
          "label": "Фиктивный адрес для клиента",
          "type": "string",
          "group": "Сетевая легенда",
          "default": "192.168.66.254"
        },
        {
          "key": "internet_facing_ip",
          "label": "Внешний IPv4",
          "type": "string",
          "group": "Сетевая легенда",
          "default": ""
        },
        {
          "key": "internet_facing_ipv6",
          "label": "Внешний IPv6",
          "type": "string",
          "group": "Сетевая легенда",
          "default": ""
        },
        {
          "key": "shell_arch",
          "label": "Архитектура shell",
          "type": "string",
          "group": "Легенда shell",
          "default": "linux-x64-lsb"
        },
        {
          "key": "kernel_version",
          "label": "Версия ядра uname",
          "type": "string",
          "group": "Легенда shell",
          "default": "3.2.0-4-amd64"
        },
        {
          "key": "kernel_build_string",
          "label": "Сборка ядра uname",
          "type": "string",
          "group": "Легенда shell",
          "default": "#1 SMP Debian 3.2.68-1+deb7u1"
        },
        {
          "key": "hardware_platform",
          "label": "Платформа uname",
          "type": "string",
          "group": "Легенда shell",
          "default": "x86_64"
        },
        {
          "key": "operating_system",
          "label": "ОС uname",
          "type": "string",
          "group": "Легенда shell",
          "default": "GNU/Linux"
        },
        {
          "key": "ssh_version",
          "label": "SSH-баннер",
          "type": "string",
          "group": "SSH/Telnet",
          "default": "SSH-2.0-OpenSSH_8.4"
        },
        {
          "key": "shell_ssh_version",
          "label": "Вывод ssh -V в shell",
          "type": "string",
          "group": "SSH/Telnet",
          "default": "OpenSSH_7.9p1, OpenSSL 1.1.1a 20 Nov 2018"
        },
        {
          "key": "proxy_backend",
          "label": "Proxy backend",
          "type": "select",
          "group": "Proxy backend",
          "default": "pool",
          "options": [
            "simple",
            "pool"
          ]
        },
        {
          "key": "backend_ssh_host",
          "label": "Backend SSH host",
          "type": "string",
          "group": "Proxy backend",
          "default": "localhost"
        },
        {
          "key": "backend_ssh_port",
          "label": "Backend SSH port",
          "type": "integer",
          "group": "Proxy backend",
          "default": 2022,
          "min": 1,
          "max": 65535
        },
        {
          "key": "backend_telnet_host",
          "label": "Backend Telnet host",
          "type": "string",
          "group": "Proxy backend",
          "default": "localhost"
        },
        {
          "key": "backend_telnet_port",
          "label": "Backend Telnet port",
          "type": "integer",
          "group": "Proxy backend",
          "default": 2023,
          "min": 1,
          "max": 65535
        },
        {
          "key": "backend_user",
          "label": "Backend user",
          "type": "string",
          "group": "Proxy backend",
          "default": "root"
        },
        {
          "key": "backend_pass_env",
          "label": "Env-переменная пароля backend",
          "type": "string",
          "group": "Proxy backend",
          "default": "COWRIE_BACKEND_PASS"
        },
        {
          "key": "raw_cowrie_cfg",
          "label": "Расширенный фрагмент cowrie.cfg",
          "type": "textarea",
          "group": "Расширенные настройки",
          "default": "",
          "help": "Необязательный raw INI-фрагмент, который добавляется к cowrie.cfg."
        }
      ]
    },
    {
      "id": "opencanary",
      "title": "OpenCanary",
      "source": "https://github.com/thinkst/opencanary",
      "documentation": "https://www.opencanary.org/en/latest/starting/configuration.html",
      "purpose": "Лёгкий многопротокольный honeypot раннего предупреждения",
      "priority": 2,
      "status": "planned-first-class",
      "runtime": "container-module",
      "resource_class": "light",
      "services": [
        {
          "id": "http",
          "protocol": "tcp",
          "default_host_port": 8081
        },
        {
          "id": "ftp",
          "protocol": "tcp",
          "default_host_port": 2121
        },
        {
          "id": "smb",
          "protocol": "tcp",
          "default_host_port": 445
        },
        {
          "id": "redis",
          "protocol": "tcp",
          "default_host_port": 6379
        },
        {
          "id": "mysql",
          "protocol": "tcp",
          "default_host_port": 3306
        },
        {
          "id": "mssql",
          "protocol": "tcp",
          "default_host_port": 1433
        }
      ],
      "config_contract": [
        "device.node_id",
        "ip.ignorelist",
        "ftp.banner",
        "http.banner",
        "http.skin",
        "ssh.version",
        "telnet.banner",
        "mysql.banner",
        "smb.auditfile",
        "portscan.enabled",
        "logger",
        "raw_opencanary_conf"
      ],
      "config_schema": [
        {
          "key": "device.node_id",
          "label": "Идентификатор устройства",
          "type": "string",
          "group": "Устройство",
          "default": "opencanary-sensor1"
        },
        {
          "key": "device.listen_addr",
          "label": "Адрес прослушивания",
          "type": "string",
          "group": "Устройство",
          "default": "",
          "help": "Bind-адрес OpenCanary для выбранных модулей; пусто означает значение по умолчанию."
        },
        {
          "key": "ip.ignorelist",
          "label": "Игнорируемые IP/CIDR",
          "type": "list",
          "group": "Устройство",
          "default": "192.168.0.196",
          "help": "Список через запятую или перенос строки."
        },
        {
          "key": "ftp.banner",
          "label": "FTP-баннер",
          "type": "string",
          "group": "Баннеры сервисов",
          "default": "FTP server ready"
        },
        {
          "key": "http.banner",
          "label": "HTTP server banner",
          "type": "string",
          "group": "Баннеры сервисов",
          "default": "nginx/1.18.0"
        },
        {
          "key": "http.skin",
          "label": "HTTP skin",
          "type": "select",
          "group": "Баннеры сервисов",
          "default": "nasLogin",
          "options": [
            "basicLogin",
            "nasLogin"
          ]
        },
        {
          "key": "https.skin",
          "label": "HTTPS skin",
          "type": "select",
          "group": "Баннеры сервисов",
          "default": "nasLogin",
          "options": [
            "basicLogin",
            "nasLogin"
          ]
        },
        {
          "key": "https.certificate",
          "label": "Путь HTTPS-сертификата",
          "type": "string",
          "group": "TLS",
          "default": "/etc/ssl/opencanary/opencanary.pem"
        },
        {
          "key": "https.key",
          "label": "Путь HTTPS-ключа",
          "type": "string",
          "group": "TLS",
          "default": "/etc/ssl/opencanary/opencanary.key"
        },
        {
          "key": "httpproxy.skin",
          "label": "HTTP proxy skin",
          "type": "select",
          "group": "Баннеры сервисов",
          "default": "squid",
          "options": [
            "squid",
            "ms-isa"
          ]
        },
        {
          "key": "mysql.banner",
          "label": "MySQL-баннер",
          "type": "string",
          "group": "Баннеры сервисов",
          "default": "5.5.43-0ubuntu0.14.04.1"
        },
        {
          "key": "ssh.version",
          "label": "Версия SSH",
          "type": "string",
          "group": "Баннеры сервисов",
          "default": "SSH-2.0-OpenSSH_5.1p1 Debian-4"
        },
        {
          "key": "telnet.banner",
          "label": "Telnet-баннер",
          "type": "string",
          "group": "Баннеры сервисов",
          "default": ""
        },
        {
          "key": "telnet.honeycreds",
          "label": "Telnet honey credentials",
          "type": "textarea",
          "group": "Учётные данные",
          "default": "admin:TopsyKretts",
          "help": "Одна пара username:password на строку."
        },
        {
          "key": "smb.auditfile",
          "label": "Путь Samba audit log",
          "type": "string",
          "group": "SMB",
          "default": "/var/log/samba-audit.log"
        },
        {
          "key": "portscan.enabled",
          "label": "Включить отслеживание portscan",
          "type": "boolean",
          "group": "Portscan",
          "default": false
        },
        {
          "key": "portscan.logfile",
          "label": "Лог-файл portscan",
          "type": "string",
          "group": "Portscan",
          "default": "/var/log/kern.log"
        },
        {
          "key": "portscan.synrate",
          "label": "SYN rate portscan",
          "type": "integer",
          "group": "Portscan",
          "default": 5,
          "min": 1
        },
        {
          "key": "portscan.nmaposrate",
          "label": "Nmap OS rate",
          "type": "integer",
          "group": "Portscan",
          "default": 5,
          "min": 1
        },
        {
          "key": "portscan.lorate",
          "label": "Low scan rate",
          "type": "integer",
          "group": "Portscan",
          "default": 3,
          "min": 1
        },
        {
          "key": "logger.mode",
          "label": "Режим логирования",
          "type": "select",
          "group": "Логирование",
          "default": "file",
          "options": [
            "console",
            "file",
            "syslog-unix",
            "json-tcp",
            "webhook"
          ]
        },
        {
          "key": "logger.file",
          "label": "Файл логов",
          "type": "string",
          "group": "Логирование",
          "default": "/var/tmp/opencanary.log"
        },
        {
          "key": "logger.json_tcp_host",
          "label": "JSON TCP host",
          "type": "string",
          "group": "Логирование",
          "default": "127.0.0.1"
        },
        {
          "key": "logger.json_tcp_port",
          "label": "JSON TCP port",
          "type": "integer",
          "group": "Логирование",
          "default": 1514,
          "min": 1,
          "max": 65535
        },
        {
          "key": "logger.webhook_url",
          "label": "Webhook URL",
          "type": "string",
          "group": "Логирование",
          "default": ""
        },
        {
          "key": "raw_opencanary_conf",
          "label": "Расширенный JSON opencanary.conf",
          "type": "textarea",
          "group": "Расширенные настройки",
          "default": "",
          "help": "Необязательный JSON overlay для ключей, которых нет в форме."
        }
      ]
    },
    {
      "id": "heralding",
      "title": "Heralding",
      "source": "https://github.com/johnnykv/heralding",
      "documentation": "https://github.com/johnnykv/heralding",
      "purpose": "Низкоинтерактивные сервисы для сбора попыток входа и учётных данных",
      "priority": 3,
      "status": "planned",
      "runtime": "container-module",
      "resource_class": "light",
      "services": [
        {
          "id": "ftp",
          "protocol": "tcp",
          "default_host_port": 2122
        },
        {
          "id": "http",
          "protocol": "tcp",
          "default_host_port": 8082
        },
        {
          "id": "pop3",
          "protocol": "tcp",
          "default_host_port": 110
        },
        {
          "id": "smtp",
          "protocol": "tcp",
          "default_host_port": 25
        }
      ],
      "config_contract": [
        "enabled_protocols",
        "listen_addr",
        "auth_logfile",
        "session_csv_logfile",
        "session_json_logfile",
        "banner_profile",
        "raw_heralding_yml"
      ],
      "config_schema": [
        {
          "key": "enabled_protocols",
          "label": "Включённые протоколы",
          "type": "list",
          "group": "Протоколы",
          "default": "ftp,http,pop3,smtp"
        },
        {
          "key": "listen_addr",
          "label": "Адрес прослушивания",
          "type": "string",
          "group": "Протоколы",
          "default": "0.0.0.0"
        },
        {
          "key": "banner_profile",
          "label": "Профиль баннеров",
          "type": "string",
          "group": "Легенда",
          "default": "enterprise-mail-and-ftp"
        },
        {
          "key": "credential_policy",
          "label": "Политика учётных данных",
          "type": "select",
          "group": "Легенда",
          "default": "capture-all",
          "options": [
            "capture-all",
            "always-fail",
            "first-step-only"
          ]
        },
        {
          "key": "auth_logfile",
          "label": "CSV-лог аутентификации",
          "type": "string",
          "group": "Логирование",
          "default": "log_auth.csv"
        },
        {
          "key": "session_csv_logfile",
          "label": "CSV-лог сессий",
          "type": "string",
          "group": "Логирование",
          "default": "log_session.csv"
        },
        {
          "key": "session_json_logfile",
          "label": "JSON-лог сессий",
          "type": "string",
          "group": "Логирование",
          "default": "log_session.json"
        },
        {
          "key": "raw_heralding_yml",
          "label": "Расширенный heralding.yml",
          "type": "textarea",
          "group": "Расширенные настройки",
          "default": ""
        }
      ]
    },
    {
      "id": "conpot",
      "title": "Conpot",
      "source": "https://github.com/mushorg/conpot",
      "documentation": "https://conpot.readthedocs.io/en/latest/",
      "purpose": "ICS/SCADA honeypot для имитации промышленного оборудования",
      "priority": 4,
      "status": "planned-after-arm-check",
      "runtime": "container-module",
      "resource_class": "medium",
      "services": [
        {
          "id": "modbus",
          "protocol": "tcp",
          "default_host_port": 502
        },
        {
          "id": "http",
          "protocol": "tcp",
          "default_host_port": 8800
        }
      ],
      "config_contract": [
        "template",
        "modbus.host",
        "modbus.port",
        "http.host",
        "http.port",
        "snmp.host",
        "snmp.port",
        "sqlite.enabled",
        "hpfriends.enabled",
        "fetch_public_ip.enabled",
        "raw_conpot_cfg"
      ],
      "config_schema": [
        {
          "key": "template",
          "label": "Шаблон",
          "type": "select",
          "group": "Шаблон",
          "default": "default",
          "options": [
            "default",
            "ipmi",
            "kamstrup_382",
            "guardian_ast"
          ]
        },
        {
