    {
      "id": "dionaea",
      "title": "Dionaea",
      "source": "https://github.com/DinoTools/dionaea",
      "documentation": "https://dionaea.readthedocs.io/en/latest/",
      "purpose": "Honeypot для сервисов и вредоносных загрузок",
      "priority": 5,
      "status": "planned-heavy",
      "runtime": "container-module",
      "resource_class": "heavy",
      "services": [
        {
          "id": "smb",
          "protocol": "tcp",
          "default_host_port": 445
        },
        {
          "id": "http",
          "protocol": "tcp",
          "default_host_port": 8083
        },
        {
          "id": "ftp",
          "protocol": "tcp",
          "default_host_port": 2123
        }
      ],
      "config_contract": [
        "services_enabled",
        "downloads_dir",
        "log_json.enabled",
        "submit_http.enabled",
        "hpfeeds.enabled",
        "sqlite.enabled",
        "p0f.enabled",
        "raw_dionaea_conf"
      ],
      "config_schema": [
        {
          "key": "services_enabled",
          "label": "Включённые сервисы",
          "type": "list",
          "group": "Сервисы",
          "default": "smb,http,ftp"
        },
        {
          "key": "service_config_dir",
          "label": "Каталог конфигов сервисов",
          "type": "string",
          "group": "Сервисы",
          "default": "/etc/dionaea/services-enabled"
        },
        {
          "key": "listen.mode",
          "label": "Режим прослушивания",
          "type": "select",
          "group": "Сервисы",
          "default": "getifaddrs",
          "options": [
            "getifaddrs",
            "manual"
          ]
        },
        {
          "key": "downloads_dir",
          "label": "Каталог malware-загрузок",
          "type": "string",
          "group": "Артефакты",
          "default": "/var/lib/dionaea/binaries"
        },
        {
          "key": "artifact_storage",
          "label": "Хранилище артефактов",
          "type": "select",
          "group": "Артефакты",
          "default": "center",
          "options": [
            "local",
            "center",
            "s3",
            "disabled"
          ]
        },
        {
          "key": "log_json.enabled",
          "label": "Включить JSON-лог",
          "type": "boolean",
          "group": "Логирование",
          "default": true
        },
        {
          "key": "log_json.path",
          "label": "Путь JSON-лога",
          "type": "string",
          "group": "Логирование",
          "default": "/var/log/dionaea/dionaea.json"
        },
        {
          "key": "sqlite.enabled",
          "label": "Включить sqlite",
          "type": "boolean",
          "group": "Логирование",
          "default": true
        },
        {
          "key": "sqlite.path",
          "label": "Путь sqlite DB",
          "type": "string",
          "group": "Логирование",
          "default": "/var/lib/dionaea/dionaea.sqlite"
        },
        {
          "key": "submit_http.enabled",
          "label": "Включить submit_http",
          "type": "boolean",
          "group": "Отправка",
          "default": false
        },
        {
          "key": "submit_http.url",
          "label": "submit_http URL",
          "type": "string",
          "group": "Отправка",
          "default": ""
        },
        {
          "key": "hpfeeds.enabled",
          "label": "Включить hpfeeds",
          "type": "boolean",
          "group": "Отправка",
          "default": false
        },
        {
          "key": "hpfeeds.host",
          "label": "hpfeeds host",
          "type": "string",
          "group": "Отправка",
          "default": ""
        },
        {
          "key": "hpfeeds.port",
