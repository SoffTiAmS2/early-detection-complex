{
  "version": 3,
  "modules": [
    {
      "id": "cowrie",
      "title": "Cowrie",
      "runtime": "container-module",
      "resource_class": "light",
      "services": [
        { "id": "ssh", "protocol": "tcp", "container_port": 2222, "default_host_port": 2222 },
        { "id": "telnet", "protocol": "tcp", "container_port": 2223, "default_host_port": 2223 }
      ],
      "config_schema": [
        { "key": "hostname", "type": "string", "default": "edge-node-01" },
        { "key": "ssh_version", "type": "string", "default": "SSH-2.0-OpenSSH_8.4" },
        { "key": "userdb_entries", "type": "textarea", "default": "root:x:!root\nadmin:x:admin" },
        { "key": "raw_cowrie_cfg", "type": "textarea", "default": "" },
        { "key": "image_mode", "type": "select", "default": "local", "options": ["local", "upstream"] },
        { "key": "base_image", "type": "string", "default": "arm32v7/debian:bookworm-slim" },
        { "key": "cowrie_ref", "type": "string", "default": "v2.6.1" }
      ]
    },
    {
      "id": "conpot",
      "title": "Conpot",
      "runtime": "container-module",
      "resource_class": "medium",
      "services": [
        { "id": "modbus", "protocol": "tcp", "container_port": 5020, "default_host_port": 15020 },
        { "id": "s7comm", "protocol": "tcp", "container_port": 10201, "default_host_port": 10102 },
        { "id": "bacnet", "protocol": "udp", "container_port": 47808, "default_host_port": 47808 },
        { "id": "http", "protocol": "tcp", "container_port": 8800, "default_host_port": 8800 },
        { "id": "ethernet_ip", "protocol": "tcp", "container_port": 44818, "default_host_port": 44818 }
      ],
      "config_schema": [
        { "key": "template", "type": "string", "default": "default" },
        { "key": "raw_conpot_cfg", "type": "textarea", "default": "" },
        { "key": "hpfriends.enabled", "type": "boolean", "default": false },
        { "key": "hpfriends.host", "type": "string", "default": "hpfriends.honeycloud.net" },
        { "key": "hpfriends.port", "type": "integer", "default": 20000, "min": 1, "max": 65535 },
        { "key": "hpfriends.channels", "type": "string", "default": "conpot.events" }
      ]
    },
    {
      "id": "mailoney",
      "title": "Mailoney",
      "runtime": "container-module",
      "resource_class": "light",
      "services": [
        { "id": "smtp", "protocol": "tcp", "container_port": 2525, "default_host_port": 2525 }
      ],
      "config_schema": [
        { "key": "hostname", "type": "string", "default": "mail-gw-01" },
        { "key": "smtp_banner", "type": "string", "default": "220 mail.example.local ESMTP" },
        { "key": "log_path", "type": "string", "default": "/logs/mailoney.log" },
        { "key": "raw_mailoney_cfg", "type": "textarea", "default": "" },
        { "key": "image_mode", "type": "select", "default": "local", "options": ["local", "upstream"] },
        { "key": "base_image", "type": "string", "default": "python:3.11-slim" }
      ]
    },
    {
      "id": "honeypy",
      "title": "HoneyPy",
      "runtime": "container-module",
      "resource_class": "medium",
      "services": [
        { "id": "http", "protocol": "tcp", "container_port": 10080, "default_host_port": 8082 },
        { "id": "https", "protocol": "tcp", "container_port": 10080, "default_host_port": 8443 },
        { "id": "http_alt", "protocol": "tcp", "container_port": 10080, "default_host_port": 8080 },
        { "id": "elasticsearch", "protocol": "tcp", "container_port": 19200, "default_host_port": 9200 },
        { "id": "echo", "protocol": "tcp", "container_port": 10007, "default_host_port": 10007 },
        { "id": "motd", "protocol": "tcp", "container_port": 10008, "default_host_port": 10008 },
        { "id": "random", "protocol": "tcp", "container_port": 12048, "default_host_port": 12048 },
        { "id": "telnet", "protocol": "tcp", "container_port": 10023, "default_host_port": 2324 }
      ],
      "config_schema": [
        { "key": "sensor_name", "type": "string", "default": "web-stack-01" },
        { "key": "http_title", "type": "string", "default": "Honeypot Web Panel" },
        { "key": "template_id", "type": "string", "default": "generic-web" },
        { "key": "fake_paths", "type": "list", "default": [] },
        { "key": "login_prompts", "type": "list", "default": [] },
        { "key": "log_path", "type": "string", "default": "/logs/honeypy.log" },
        { "key": "raw_honeypy_yml", "type": "textarea", "default": "" },
        { "key": "image_mode", "type": "select", "default": "local", "options": ["local", "upstream"] },
        { "key": "base_image", "type": "string", "default": "python:2.7-slim-buster" }
      ]
    },
    {
      "id": "glutton",
      "title": "Glutton",
      "runtime": "container-module",
      "resource_class": "medium",
      "services": [
        { "id": "docker_api", "protocol": "tcp", "container_port": 2375, "default_host_port": 2375 },
        { "id": "mqtt", "protocol": "tcp", "container_port": 1883, "default_host_port": 1883 },
        { "id": "k8s_api", "protocol": "tcp", "container_port": 6443, "default_host_port": 6443 },
        { "id": "rdp", "protocol": "tcp", "container_port": 3389, "default_host_port": 3389 },
        { "id": "vnc", "protocol": "tcp", "container_port": 5900, "default_host_port": 5900 },
        { "id": "sip", "protocol": "udp", "container_port": 5060, "default_host_port": 5060 },
        { "id": "snmp", "protocol": "udp", "container_port": 161, "default_host_port": 161 },
        { "id": "lpd", "protocol": "tcp", "container_port": 515, "default_host_port": 515 },
        { "id": "ipp", "protocol": "tcp", "container_port": 631, "default_host_port": 631 },
        { "id": "jetdirect", "protocol": "tcp", "container_port": 9100, "default_host_port": 9100 },
        { "id": "ftp", "protocol": "tcp", "container_port": 21, "default_host_port": 21 },
        { "id": "rtsp", "protocol": "tcp", "container_port": 554, "default_host_port": 554 },
        { "id": "camera_service", "protocol": "tcp", "container_port": 8000, "default_host_port": 8000 },
        { "id": "discovery", "protocol": "tcp", "container_port": 8899, "default_host_port": 8899 },
        { "id": "winbox", "protocol": "tcp", "container_port": 8291, "default_host_port": 8291 },
        { "id": "rsync", "protocol": "tcp", "container_port": 873, "default_host_port": 873 },
        { "id": "nfs", "protocol": "tcp", "container_port": 2049, "default_host_port": 2049 },
        { "id": "smb", "protocol": "tcp", "container_port": 445, "default_host_port": 445 },
        { "id": "netbios", "protocol": "tcp", "container_port": 139, "default_host_port": 139 },
        { "id": "msrpc", "protocol": "tcp", "container_port": 135, "default_host_port": 135 },
        { "id": "wsdiscovery", "protocol": "tcp", "container_port": 5357, "default_host_port": 5357 },
        { "id": "winrm", "protocol": "tcp", "container_port": 5985, "default_host_port": 5985 },
        { "id": "mysql", "protocol": "tcp", "container_port": 3306, "default_host_port": 3306 },
        { "id": "redis", "protocol": "tcp", "container_port": 6379, "default_host_port": 6379 },
        { "id": "postgres", "protocol": "tcp", "container_port": 5432, "default_host_port": 5432 },
        { "id": "pop3", "protocol": "tcp", "container_port": 110, "default_host_port": 110 },
        { "id": "imap", "protocol": "tcp", "container_port": 143, "default_host_port": 143 },
        { "id": "smtps", "protocol": "tcp", "container_port": 465, "default_host_port": 465 },
        { "id": "submission", "protocol": "tcp", "container_port": 587, "default_host_port": 587 },
        { "id": "imaps", "protocol": "tcp", "container_port": 993, "default_host_port": 993 },
        { "id": "pop3s", "protocol": "tcp", "container_port": 995, "default_host_port": 995 },
        { "id": "afp", "protocol": "tcp", "container_port": 548, "default_host_port": 548 },
        { "id": "nas_web", "protocol": "tcp", "container_port": 5000, "default_host_port": 5000 }
      ],
      "config_schema": [
        { "key": "log_path", "type": "string", "default": "/logs/glutton.json" },
        { "key": "profile_id", "type": "string", "default": "" },
        { "key": "device_type", "type": "string", "default": "" },
        { "key": "exposed_ports", "type": "list", "default": [] },
        { "key": "banners", "type": "object", "default": {} },
        { "key": "service_fingerprints", "type": "object", "default": {} },
        { "key": "raw_glutton_yml", "type": "textarea", "default": "" },
        { "key": "image_mode", "type": "select", "default": "local", "options": ["local", "upstream"] },
        { "key": "base_image", "type": "string", "default": "golang:1.23-bookworm" }
      ]
    }
  ]
}
