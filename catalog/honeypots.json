{
  "version": 3,
  "modules": [
    {
      "id": "cowrie",
      "title": "Cowrie",
      "runtime": "container-module",
      "resource_class": "light",
      "services": [
        { "id": "ssh", "protocol": "tcp", "container_port": 2222, "default_host_port": 2222 },
        { "id": "telnet", "protocol": "tcp", "container_port": 2223, "default_host_port": 2223 }
      ],
      "config_schema": [
        { "key": "hostname", "type": "string", "default": "edge-node-01" },
        { "key": "ssh_version", "type": "string", "default": "SSH-2.0-OpenSSH_8.4" },
        { "key": "userdb_entries", "type": "textarea", "default": "root:x:!root\nadmin:x:admin" },
        { "key": "raw_cowrie_cfg", "type": "textarea", "default": "" },
        { "key": "image_mode", "type": "select", "default": "local", "options": ["local", "upstream"] },
        { "key": "base_image", "type": "string", "default": "arm32v7/debian:bookworm-slim" },
        { "key": "cowrie_ref", "type": "string", "default": "v2.6.1" }
      ]
    },
    {
      "id": "conpot",
      "title": "Conpot",
      "runtime": "container-module",
      "resource_class": "medium",
      "services": [
        { "id": "modbus", "protocol": "tcp", "container_port": 5020, "default_host_port": 15020 },
        { "id": "s7comm", "protocol": "tcp", "container_port": 10200, "default_host_port": 10102 },
        { "id": "bacnet", "protocol": "udp", "container_port": 47808, "default_host_port": 47808 },
        { "id": "http", "protocol": "tcp", "container_port": 8800, "default_host_port": 8800 }
      ],
      "config_schema": [
        { "key": "template", "type": "string", "default": "default" },
        { "key": "raw_conpot_cfg", "type": "textarea", "default": "" },
        { "key": "hpfriends.enabled", "type": "boolean", "default": false },
        { "key": "hpfriends.host", "type": "string", "default": "hpfriends.honeycloud.net" },
        { "key": "hpfriends.port", "type": "integer", "default": 20000, "min": 1, "max": 65535 },
        { "key": "hpfriends.channels", "type": "string", "default": "conpot.events" }
      ]
    },
    {
      "id": "mailoney",
      "title": "Mailoney",
      "runtime": "container-module",
      "resource_class": "light",
      "services": [
        { "id": "smtp", "protocol": "tcp", "container_port": 2525, "default_host_port": 2525 }
      ],
      "config_schema": [
        { "key": "hostname", "type": "string", "default": "mail-gw-01" },
        { "key": "smtp_banner", "type": "string", "default": "220 mail.example.local ESMTP" },
        { "key": "log_path", "type": "string", "default": "/logs/mailoney.log" },
        { "key": "raw_mailoney_cfg", "type": "textarea", "default": "" },
        { "key": "image_mode", "type": "select", "default": "local", "options": ["local", "upstream"] },
        { "key": "base_image", "type": "string", "default": "python:3.11-slim" }
      ]
    },
    {
      "id": "honeypy",
      "title": "HoneyPy",
      "runtime": "container-module",
      "resource_class": "medium",
      "services": [
        { "id": "http", "protocol": "tcp", "container_port": 8082, "default_host_port": 8082 },
        { "id": "mysql", "protocol": "tcp", "container_port": 3307, "default_host_port": 3307 },
        { "id": "redis", "protocol": "tcp", "container_port": 6380, "default_host_port": 6380 },
        { "id": "ftp", "protocol": "tcp", "container_port": 2124, "default_host_port": 2124 },
        { "id": "telnet", "protocol": "tcp", "container_port": 2324, "default_host_port": 2324 }
      ],
      "config_schema": [
        { "key": "sensor_name", "type": "string", "default": "web-stack-01" },
        { "key": "log_path", "type": "string", "default": "/logs/honeypy.log" },
        { "key": "raw_honeypy_yml", "type": "textarea", "default": "" },
        { "key": "image_mode", "type": "select", "default": "local", "options": ["local", "upstream"] },
        { "key": "base_image", "type": "string", "default": "python:3.11-slim" }
      ]
    },
    {
      "id": "glutton",
      "title": "Glutton",
      "runtime": "container-module",
      "resource_class": "medium",
      "services": [
        { "id": "docker_api", "protocol": "tcp", "container_port": 2375, "default_host_port": 2375 },
        { "id": "mqtt", "protocol": "tcp", "container_port": 1883, "default_host_port": 1883 },
        { "id": "k8s_api", "protocol": "tcp", "container_port": 6443, "default_host_port": 6443 },
        { "id": "rdp", "protocol": "tcp", "container_port": 3389, "default_host_port": 3389 },
        { "id": "vnc", "protocol": "tcp", "container_port": 5900, "default_host_port": 5900 },
        { "id": "sip", "protocol": "udp", "container_port": 5060, "default_host_port": 5060 }
      ],
      "config_schema": [
        { "key": "log_path", "type": "string", "default": "/logs/glutton.json" },
        { "key": "raw_glutton_yml", "type": "textarea", "default": "" },
        { "key": "image_mode", "type": "select", "default": "local", "options": ["local", "upstream"] },
        { "key": "base_image", "type": "string", "default": "golang:1.22-bookworm" }
      ]
    }
  ]
}
