COMPOSE_PROJECT_NAME=early-detection-complex

# Center storage. Docker Compose uses PostgreSQL by default.
CENTER_DB_DSN=postgresql://edc:edc@postgres:5432/edc

# Sensor helper defaults for scripts/run_sensor_runtime.sh.
EDC_CENTER_URL=http://127.0.0.1:8080
EDC_SENSOR_ID=banana-pi-pro-1
EDC_INTERVAL=15
